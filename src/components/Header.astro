<script>
  const nav = document.querySelector("header nav") as HTMLElement;
  const top = nav.querySelector(".top") as HTMLElement;
  const bottom = nav.querySelector(".bottom") as HTMLElement;
  // function setHeaderPos() {
  //   const pos = ((x) => (x < 1 ? Math.sin((Math.PI * x) / 2) : 1))(
  //     window.pageYOffset / window.innerHeight
  //   );
  //   nav.style.height = `${pos * 48 + (1 - pos) * window.innerHeight}px`;
  //   // nav.style.top = `${10 + (1 - pos) * window.innerHeight / 2}px`;
  //   nav.style.width = `${60 + 30 * pos}%`;
  // }
  // (window.onresize = window.onscroll = setHeaderPos)();
  const slides = document.querySelectorAll("section");
  const links = nav.querySelectorAll("a");
  let active = 0;
  for (let i = 0; i < 4; i++) {
    (links[i] as HTMLElement).onclick = function (e) {
      const sgn = Math.sign(i - active);
      const dir = active * i === 0 ? "Y" : "X";
      console.log(sgn, dir)
      if (sgn !== 0) {
        if (active === 0) {
          top.style.width = "100vw";
          top.style.height = "40px";
          bottom.style.transform = "translateY(0)";
        } else if (i === 0) {
          top.style.width = "80vw";
          top.style.height = "100vh";
          bottom.style.transform = "translateY(100%)";
        }
        slides[active].style.transform = `translate${dir}(${-sgn * 100}%)`;
        window.setTimeout(
          function (active: number) {
            slides[active].style.display = "none";
          },
          400,
          active
        );
        active = i;
        slides[active].style.display = "flex";
        slides[active].style.transform = `translate${dir}(${sgn * 100}%)`;
        window.setTimeout(
          function (active: number) {
            slides[active].style.transform = `translate${dir}(0)`;
          },
          0,
          active
        );
      }
    };
  }
</script>
<header>
  <nav>
    <div class="bottom" style="transform:translateY(100%)">
      <a href="#">Home</a>
    </div>
    <div class="top">
      <a class="left" href="#">About</a>
      <a class="center" href="#">Reel</a>
      <a class="right" href="#">Contact</a>
    </div>
  </nav>
</header>
<style>
  nav .top,
  nav .bottom {
    position: fixed;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: auto;
    text-transform: uppercase;
    letter-spacing: 12px;
    z-index: 5;
  }
  nav .top {
    inset: 0 0 auto;
    width: 80vw;
    height: 100vh;
    transition: width 400ms, height 400ms;
  }
  nav .bottom {
    inset: auto 0 0;
    width: 100vw;
    height: 40px;
    transition: transform 400ms;
  }
  a {
    padding: 0 10px;
  }
  a.left {
    position: absolute;
    align-self: start;
  }
  a.center {
    position: absolute;
    /* align-self: center; */
  }
  a.right {
    position: absolute;
    align-self: end;
  }
</style>
