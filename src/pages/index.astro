---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section style="display: none;">
    <article>
      <p>
        I am a cinematographer focusing on documentary, fictional and
        advertorial projects that investigate socially relevant topics.
      </p>
      <p>
        Shaping light and composing images is a powerful tool to emotionally
        catch the audience, making them reflect on issues and phenomena they're
        possibly unaware of.
      </p>
      <p>
        Besides entertainment, i see our responsibility as filmmakers to use
        that power for making a positive impact, regardless of what extent.
      </p>
    </article>
  </section>
  <section class="reel" style="display: none;">
    <iframe
      src="https://player.vimeo.com/video/670168289?h=ec2e1f4cdf"
      allow="autoplay"></iframe>
  </section>
  <section style="display: none;">
    <article>
      <a href="tel:+436643921524">+43 664 392 15 24</a>
      <a href="mailto:mail@camillorakos.com">mail@camillorakos.com</a>
      <p>
        Camillo Rakoš
        <br />
        Vienna, Austria
      </p>
    </article>
  </section>
</Layout>
<style>
  section {
    position: fixed;
    width: 100vw;
    height: 100vh;
    align-items: center;
    justify-content: center;
    padding: 40px 0;
    overflow: hidden;
    transition: transform 400ms;
  }
  section.reel {
    background: black;
  }
  article {
    width: 512px;
    text-align: center;
  }
  p {
    margin-top: 20px;
  }
  iframe {
    width: 100vw;
    height: 100vh;
  }
  iframe {
    width: 90%;
    height: 100%;
    margin: auto;
  }
</style>
